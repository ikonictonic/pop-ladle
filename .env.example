NODE_ENV=development
HOST=0.0.0.0
PORT=9000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pop_ladle
CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me

# Outbound email (invites). Leave RESEND_API_KEY blank to use the console
# transport in dev — invite emails are logged instead of sent.
RESEND_API_KEY=
EMAIL_FROM=Pop & Ladle <onboarding@resend.dev>
# Public app origin used to build absolute invite links in emails.
APP_BASE_URL=http://localhost:5173

# Encryption secret for platform LLM provider API keys stored in the DB
# (platform_provider_keys, managed via /admin/provider-keys and /admin/roster).
# Any long random string; used to derive an AES-256-GCM key. If UNSET, the
# provider-key WRITE endpoints return 503 (fail closed — nothing is ever stored
# in plaintext) and the recipe-brain proxy falls back to the *_API_KEY env vars.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PROVIDER_KEY_ENC_SECRET=

# Recipe Brain provider keys — legacy env fallback (used when no DB key is set
# for a provider/specialist). Production prefers DB-managed keys above.
ANTHROPIC_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=

# Object storage for recipe photos (S3-compatible — Cloudflare R2).
# Private bucket; leave blank to disable photo features (endpoints return 503).
# R2 endpoint looks like https://<accountid>.r2.cloudflarestorage.com
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
