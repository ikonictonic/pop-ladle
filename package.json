{
  "name": "pop-ladle-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.11.0"
  },
  "scripts": {
    "dev": "node --env-file-if-exists=.env --env-file-if-exists=.env.local --watch src/server.js",
    "db:migrate": "node --env-file-if-exists=.env src/database/migrate.js",
    "start": "node --env-file-if-exists=.env src/server.js",
    "abac:compile": "node scripts/compile-abac-policy.mjs",
    "test": "node --test \"src/**/*.test.js\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1066.0",
    "@aws-sdk/s3-request-presigner": "^3.1066.0",
    "@clerk/express": "^2.1.23",
    "express": "^5.2.1",
    "pg": "^8.21.0"
  }
}
